# Intake Auth Server Configuration

# Port the server listens on (default: 3699)
PORT=3699

# Comma-separated list of allowed CORS origins.
# Include your GitHub Pages domain and local dev URLs.
ALLOWED_ORIGINS=https://intake.ddonlien.com,http://localhost:5173

# Directory for persistent data (users, sessions).
# On Vercel, use /tmp (default) or Vercel KV for cross-instance persistence.
INTAKE_DATA_DIR=./data

# Session lifetime in milliseconds (default: 7 days).
SESSION_MAX_AGE_MS=604800000

# Basic in-memory rate limit for register/login routes.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30

# Admin API key for the registration management dashboard.
# Set this to a long random string. The frontend passes it via x-admin-key header.
# If unset, admin endpoints return 403.
ADMIN_API_KEY=

# Gemini API key for AI food recognition via /api/scan.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Vercel KV (optional, for cross-instance persistence).
# Create at: Vercel Dashboard → Project → Storage → KV
# KV_REST_API_URL and KV_REST_API_TOKEN are auto-injected when KV is connected.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
